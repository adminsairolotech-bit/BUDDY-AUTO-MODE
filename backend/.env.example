HOST=0.0.0.0
PORT=8001
APP_ENV=development
MONGO_URL=mongodb://localhost:27017
DB_NAME=openclaw_db
JWT_SECRET_KEY=change-this-secret-in-production
JWT_REFRESH_SECRET_KEY=change-this-refresh-secret-in-production
JWT_PREV_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
ENCRYPTION_KEY=replace-with-fernet-key
DESKTOP_SIGNING_SECRET=
REQUIRE_SECURE_TRANSPORT=false
ALLOW_INSECURE_LOCALHOST=true
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WEATHER_API_KEY=
NEWS_API_KEY=

# ULTIMATE v5 Loop Controls
ULTIMATE_MAX_CYCLES=5
ULTIMATE_ERROR_REPEAT_LIMIT=2
ULTIMATE_MAX_PIPELINE_RUN=5
ULTIMATE_MEMORY_DIR=.ai_memory
